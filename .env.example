# Zilliz Cloud credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get these from: https://cloud.zilliz.com → Clusters → verimed-dev → Connect tab
#
# ZILLIZ_TOKEN accepts either format:
#   - Cluster token (user:password pair from the Connect tab)
#   - API key (generate at top-right "API Keys" nav link)

ZILLIZ_ENDPOINT=https://in03-xxxxxxx.serverless.aws-eu-central-1.cloud.zilliz.com
ZILLIZ_TOKEN=your-token-or-api-key-here
